FROM node:20-alpine AS base
WORKDIR /app
RUN apk add --no-cache net-snmp-dev python3 make g++

FROM base AS deps
COPY package*.json ./
RUN npm ci --omit=dev

FROM base AS final
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN mkdir -p data logs

EXPOSE 3000
ENV NODE_ENV=production
CMD ["node", "server.js"]
