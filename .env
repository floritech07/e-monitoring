# VMware Workstation configuration
# Optional: Change to 'api' or 'vmrun' to override auto-detection
# VMWARE_DRIVER=auto

# Path to vmrun.exe (relative or absolute)
VMRUN_PATH="C:\\Program Files (x86)\\VMware\\VMware Workstation\\vmrun.exe"

# VMware REST API credentials (base64 encoded admin:password by default)
# Access at http://127.0.0.1:8697/api
# Run 'vmrest.exe' to enable the API
VMWARE_API_URL="http://127.0.0.1:8697/api"
VMWARE_API_USER="admin"
VMWARE_API_PASS="admin"

# Backend configuration
PORT=3001
NODE_ENV=development

# MySQL Databases (Payment Monitoring)
DB_PREPAID_HOST=127.0.0.1
DB_PREPAID_USER=root
DB_PREPAID_PASSWORD=
DB_PREPAID_NAME=smartvend

DB_POSTPAID_HOST=127.0.0.1
DB_POSTPAID_USER=root
DB_POSTPAID_PASSWORD=
DB_POSTPAID_NAME=middleware_prod
