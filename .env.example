# SBEE Monitoring — Configuration

# ─── Serveur ──────────────────────────────────────────────────────────────────
PORT=3001

# ─── VMware Workstation / Fusion (auto-rempli au démarrage si VMware est détecté) ───
VMRUN_PATH=

# ─── VirtualBox (auto-rempli si VirtualBox est détecté) ──────────────────────
VBOXMANAGE_PATH=

# ─── Base de données Prépayé (optionnel) ─────────────────────────────────────
DB_PREPAID_HOST=
DB_PREPAID_USER=
DB_PREPAID_PASS=
DB_PREPAID_NAME=

# ─── Base de données Postpayé (optionnel) ────────────────────────────────────
DB_POSTPAID_HOST=
DB_POSTPAID_USER=
DB_POSTPAID_PASS=
DB_POSTPAID_NAME=

# ─── Veeam Backup & Replication (optionnel) ──────────────────────────────────
VEEAM_HOST=
VEEAM_PORT=9419
VEEAM_USER=
VEEAM_PASS=
