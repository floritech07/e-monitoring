# NexusMonitor v2 — Variables d'environnement
# Copier vers .env et adapter les valeurs avant démarrage

# ─── Serveur ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nexusmonitor
POSTGRES_USER=nexus
POSTGRES_PASSWORD=NexusS3cure!2026

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=RedisS3cure!2026

# ─── VictoriaMetrics ──────────────────────────────────────────────────────────
VICTORIA_URL=http://localhost:8428

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=ChangeThisSecretInProduction2026abcdef1234567890

# ─── SNMP v3 — UPS Su-Kam ─────────────────────────────────────────────────────
SNMP_UPS_HOST=192.168.10.50
SNMP_UPS_USER=nexusv3
SNMP_UPS_AUTH_KEY=AuthPassphraseUPS2026
SNMP_UPS_PRIV_KEY=PrivPassphraseUPS2026

# ─── SNMP v3 — Switch HPE Aruba ───────────────────────────────────────────────
SNMP_SW_HOST=192.168.10.1
SNMP_SW_USER=nexusv3
SNMP_SW_AUTH_KEY=AuthPassphraseSW2026
SNMP_SW_PRIV_KEY=PrivPassphraseSW2026

# ─── Redfish — HPE iLO ESXi-01 ───────────────────────────────────────────────
REDFISH_ESXi01_HOST=192.168.10.11
REDFISH_ESXi01_USER=administrator
REDFISH_ESXi01_PASS=iLOPassword2026

# ─── vCenter REST API (Phase 2, laisser vide en Phase 0) ─────────────────────
VCENTER_HOST=
VCENTER_USER=
VCENTER_PASS=

# ─── Veeam B&R REST API ───────────────────────────────────────────────────────
VEEAM_HOST=
VEEAM_PORT=9419
VEEAM_USER=
VEEAM_PASS=

# ─── Email alertes ────────────────────────────────────────────────────────────
SMTP_HOST=mail.sbee.bj
SMTP_PORT=587
SMTP_USER=nexusmonitor@sbee.bj
SMTP_PASS=SmtpPassword2026
