# NexusMonitor Enterprise Suite
# ------------------------------------------------------------------
# Required Environment Variables for Local Development & Production
# Copy this file to .env and configure accordingly.

# Database Layer
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nexusmonitor
DB_ENGINE=postgresql
REDIS_URL=redis://localhost:6379/0
KAFKA_BROKERS=localhost:9092

# Authentication & Security
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
ENCRYPTION_KEY="paste_generated_fernet_key_here"

# S3 Compatible Storage (Backups, Documents, Reports)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password

# External Logs / Metrics Search (optional)
ELASTICSEARCH_URL=http://localhost:9200

# Alerting Channels - SMTP Configuration
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@domain.com
SMTP_PASSWORD=mailgun_secret

# Alerting Channels - SMS/Voice via Twilio
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Alerting Channels - Push Notifications
FCM_SERVER_KEY=your_firebase_cloud_messaging_key
